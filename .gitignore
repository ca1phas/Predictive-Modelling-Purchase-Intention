# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site
docs/

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# =========================================
# UECM3993 Project-Specific Exclusions
# =========================================

# Exclude all generated datasets and preprocessing artifacts
outputs/data/

# Exclude all generated plots and visualizations
outputs/figures/

# Exclude saved model binaries (reduces repository bloat and prevents Git conflicts)
outputs/models/

# Exclude renv package library (renv usually creates its own .gitignore inside the folder, 
# but putting it here acts as a strict fail-safe)
renv/library/
renv/python/
renv/staging/